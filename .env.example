# Copy to .env on the server. Never commit the real values.
# Public HTTPS origin used by Supabase Edge Functions. This is not a secret.
PUBLIC_ENGINE_URL=https://engine.cridergpt.com
CRIDERGPT_ENGINE_API_KEY=replace-with-the-same-value-as-the-supabase-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-on-server-only

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=2000

# Automatic1111 or Forge API running on the GPU server.
IMAGE_BACKEND=automatic1111
IMAGE_API_URL=http://127.0.0.1:7860
IMAGE_MODEL=
IMAGE_TIMEOUT_SECONDS=180
MAX_REFERENCE_IMAGES=4
# Restrict remote image downloads. Add only trusted reference-image hosts.
ALLOWED_REFERENCE_HOSTS=your-project.supabase.co

CRIDERGPT_FOUNDER_NAME=Jessie Crider
CRIDERGPT_FOUNDER_EMAIL=jessiecrider3@gmail.com
MEMORY_CONTEXT_LIMIT=20
WRITING_SAMPLE_LIMIT=8
TRAINING_CONTEXT_LIMIT=10
PERSIST_DIRECT_CHAT=false
LOG_LEVEL=INFO
