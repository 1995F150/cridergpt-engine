limit_req_zone $binary_remote_addr zone=cridergpt_engine:10m rate=30r/m;

server {
    listen 443 ssl http2;
    server_name engine.cridergpt.com;

    ssl_certificate /etc/letsencrypt/live/engine.cridergpt.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/engine.cridergpt.com/privkey.pem;
    client_max_body_size 16m;

    location / {
        limit_req zone=cridergpt_engine burst=10 nodelay;
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_read_timeout 190s;
        proxy_connect_timeout 10s;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
